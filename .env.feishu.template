# =============================================================================
# Feishu Bot 环境变量配置模板
# 复制此文件为 .env.feishu 并填写实际值
# =============================================================================

# =============================================================================
# 飞书应用凭证（从飞书开放平台获取）
# =============================================================================

# 飞书应用ID (App ID)
# 获取位置: 飞书开放平台 > 应用详情 > 凭证信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx

# 飞书应用密钥 (App Secret)  
# 获取位置: 飞书开放平台 > 应用详情 > 凭证信息
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 事件订阅验证Token (Verification Token)
# 获取位置: 飞书开放平台 > 事件与回调 > 事件订阅
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 消息加密密钥 (Encrypt Key)
# 获取位置: 飞书开放平台 > 事件与回调 > 加密策略
# 如果未启用加密，可留空
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OpenCode 配置
# =============================================================================

# 默认项目路径（飞书Bot使用的默认项目）
# 注意: 这是服务器上的路径，用于MVP版本
OPENCODE_DEFAULT_PROJECT=/home/ubuntu/repos/SailZen

# OpenCode服务端口
OPENCODE_PORT=4096

# OpenCode认证密码（如果启用了HTTP Basic Auth）
# 留空表示无需认证
OPENCODE_AUTH_PASSWORD=

# =============================================================================
# 本地Agent配置（开发机使用）
# =============================================================================

# 云端WebSocket地址（用于本地Agent连接）
# 格式: wss://your-domain.com/ws 或 ws://localhost:8080
AGENT_CLOUD_URL=wss://your-domain.com/ws

# Agent连接PIN码（6位数字）
# 用于验证本地Agent身份
AGENT_PIN=123456

# Agent心跳间隔（秒）
AGENT_HEARTBEAT_INTERVAL=5

# Agent状态检查间隔（秒）
AGENT_CHECK_INTERVAL=5

# =============================================================================
# 功能开关
# =============================================================================

# 启用Feishu Bot功能: true | false
ENABLE_FEISHU_BOT=true

# 启用WebSocket连接（后续版本）: true | false
ENABLE_WEBSOCKET=false

# 启用期望状态自动同步（后续版本）: true | false
ENABLE_DESIRED_STATE_SYNC=false

# =============================================================================
# 安全配置
# =============================================================================

# Webhook签名验证: true | false
# 生产环境建议开启
FEISHU_VERIFY_SIGNATURE=true

# 允许的飞书租户Key列表（可选，用于多租户限制）
# 留空表示接受所有租户
FEISHU_ALLOWED_TENANTS=

# =============================================================================
# 速率限制配置
# =============================================================================

# 每个用户的最大并发任务数
MAX_CONCURRENT_TASKS_PER_USER=3

# 飞书API调用速率限制（每分钟）
FEISHU_RATE_LIMIT_RPM=100

# =============================================================================
# 配置获取指南
# =============================================================================
#
# 1. 创建飞书应用:
#    - 访问 https://open.feishu.cn/
#    - 创建企业自建应用
#    - 启用"机器人"能力
#
# 2. 获取凭证:
#    - App ID 和 App Secret: 应用详情 > 凭证信息
#    - Verification Token: 事件与回调 > 事件订阅
#    - Encrypt Key: 事件与回调 > 加密策略（可选）
#
# 3. 配置权限:
#    - im:message.group_at_msg:readonly
#    - im:message.p2p_msg:readonly
#    - im:message:send
#
# 4. 配置事件订阅:
#    - 请求地址: https://your-domain.com/api/v1/feishu/webhook
#    - 订阅事件: im.message.receive_v1
#
# 5. 发布应用:
#    - 创建版本并申请发布
#    - 管理员审批通过
#
# 6. 添加机器人到群组:
#    - 群组设置 > 群机器人 > 添加机器人
#
# =============================================================================
