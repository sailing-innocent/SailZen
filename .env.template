# =============================================================================
# SailZen 环境变量配置模板
# 复制此文件为 .env.dev（开发环境）或 .env.prod（生产环境）并填写实际值
# =============================================================================

# =============================================================================
# 服务器配置 (server.py)
# =============================================================================

# 服务器监听端口 (默认: 1974)
SERVER_PORT=4399

# 服务器监听地址 (默认: 0.0.0.0)
SERVER_HOST=0.0.0.0

# API 端点前缀 (默认: /api/v1)
API_ENDPOINT=/api/v1

# 前端站点静态文件目录 (默认: site_dist)
SITE_DIST=site_dist

# 服务器日志文件路径
SERVER_LOG_FILE=E:/ws/logs/server.log

# =============================================================================
# 数据库配置 (sail_server/db.py)
# =============================================================================

# PostgreSQL 数据库连接 URI
# 格式: postgresql://username:password@host:port/database
# 示例: postgresql://postgres:password@localhost:5432/main
POSTGRE_URI=postgresql:///main

# 注意: 程序会自动设置 PGCLIENTENCODING=UTF8，无需手动配置

# =============================================================================
# 异步大纲提取配置 (Async Outline Extraction)
# =============================================================================

# 启用异步并行大纲提取: true | false
# 启用后会使用新的异步并行架构，大幅提升大纲提取速度
# 默认: false（使用旧的串行模式）
USE_ASYNC_OUTLINE_EXTRACTION=false

# 异步提取配置（仅在启用时有效）
# 并发限制（建议根据 LLM API 限制调整，默认: 100）
ASYNC_EXTRACTION_MAX_CONCURRENT=100

# RPM 限制（每分钟请求数，默认: 400，预留 20% 缓冲）
ASYNC_EXTRACTION_RPM_LIMIT=400

# TPM 限制（每分钟 Token 数，默认: 2400000，预留 20% 缓冲）
ASYNC_EXTRACTION_TPM_LIMIT=2400000

# =============================================================================
# 日志配置 (sail_server/utils/logging_config.py)
# =============================================================================

# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
# - DEBUG: 开发调试时使用，记录所有信息
# - INFO: 默认级别，记录一般信息、警告和错误
# - WARNING: 只记录警告和错误
# - ERROR: 只记录错误
LOG_LEVEL=INFO

# 日志目录 (默认: logs)
LOG_DIR=logs

# 数据库调试日志: true | false
# 启用后会记录 SQL 查询详情
DB_DEBUG=false

# =============================================================================
# LLM Provider API 配置
# 至少配置一个 Provider 才能使用 AI 功能
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI 配置
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1  # 可选，用于代理或自定义端点

# -----------------------------------------------------------------------------
# Anthropic (Claude) 配置
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-haiku-20240307

# -----------------------------------------------------------------------------
# Google Gemini 配置
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Moonshot (Kimi) 配置 - 项目默认推荐
# -----------------------------------------------------------------------------
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOONSHOT_MODEL=kimi-k2.5
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# -----------------------------------------------------------------------------
# DeepSeek 配置 - 第一候补 Provider (高性价比)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com  # 可选，用于代理或自定义端点

# =============================================================================
# 本地 LLM 配置 (可选)
# =============================================================================

# Ollama 服务地址 (用于本地模型)
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# 测试配置 (可选)
# =============================================================================

# 跳过数据库测试: true | false
SKIP_DB_TESTS=false

# =============================================================================
# 配置说明
# =============================================================================
#
# 1. 必需配置:
#    - POSTGRE_URI: 数据库连接
#    - 至少一个 LLM Provider API Key (推荐使用 MOONSHOT_API_KEY)
#
# 2. 开发环境建议 (.env.dev):
#    - LOG_LEVEL=DEBUG
#    - DB_DEBUG=true
#
# 3. 生产环境建议 (.env.prod):
#    - LOG_LEVEL=INFO
#    - DB_DEBUG=false
#
# 4. 速率限制处理:
#    当遇到 429 错误时，系统会自动:
#    - 指数退避重试 (最多3次)
#    - 如果配置了多个 Provider，可手动切换到其他 Provider
#
# 5. 配置文件优先级:
#    .env.debug > .env.dev > .env.prod > 系统环境变量
#
# 6. 启动模式:
#    - python server.py --dev   : 使用 .env.dev 配置
#    - python server.py --prod  : 使用 .env.prod 配置 (默认)
#
# =============================================================================
