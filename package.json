{
    "name": "@saili/sailzen",
    "private": true,
    "scripts": {
        "install-site": "pnpm install --filter=sail-site",
        "build-site": "pnpm -r --filter=sail-site run build",
        "install-plugin": "pnpm install --filter=sail-zen-vscode",
        "build-engine-server": "node scripts/build-with-deps.js @saili/engine-server",
        "build-plugin": "node scripts/build-with-deps.js sail-zen-vscode build",
        "package-plugin": "pnpm -r --filter=sail-zen-vscode run package",
        "build:common-all": "node scripts/build-with-deps.js @saili/common-all",
        "build:common-server": "node scripts/build-with-deps.js @saili/common-server",
        "build:unified": "node scripts/build-with-deps.js @saili/unified",
        "build:api-server": "node scripts/build-with-deps.js @saili/api-server",
        "build-with-deps": "node scripts/build-with-deps.js",
        "test": "pnpm -r --filter=\"./packages/common-all\" --filter=\"./packages/common-server\" --filter=\"./packages/unified\" run test",
        "test:common-all": "pnpm --filter=\"./packages/common-all\" run test",
        "test:common-server": "pnpm --filter=\"./packages/common-server\" run test",
        "test:unified": "pnpm --filter=\"./packages/unified\" run test",
        "test:coverage": "pnpm -r --filter=\"./packages/common-all\" --filter=\"./packages/common-server\" --filter=\"./packages/unified\" run test:coverage",
        "views:dev": "pnpm --filter=@saili/dendron-plugin-views run dev",
        "views:build": "pnpm --filter=@saili/dendron-plugin-views run build",
        "views:copy": "pnpm --filter=@saili/dendron-plugin-views run copy-to-plugin",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major"
    }
}