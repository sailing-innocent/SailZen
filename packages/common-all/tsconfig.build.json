{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "lib",
    "rootDir": "src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*-spec.ts",
    "**/*.test.ts",
    "**/__tests__/**/*",
    "**/*.d.ts"
  ]
}