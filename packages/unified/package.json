{
  "name": "@saili/unified",
  "version": "0.1.0",
  "type": "module",
  "description": "Unified parser utilities for Dendron",
  "license": "MIT",
  "keywords": [
    "common"
  ],
  "files": [
    "lib"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf lib && rimraf coverage",
    "prepublishOnly": "pnpm build",
    "prebuild": "pnpm clean",
    "build": "pnpm compile",
    "test": "pnpm exec cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "buildCI": "pnpm compile",
    "compile": "tsc -p tsconfig.build.json",
    "watch": "pnpm compile --watch"
  },
  "dependencies": {
    "@mapbox/rehype-prism": "^0.9.0",
    "@saili/common-all": "workspace:^",
    "js-yaml": "^4.1.1",
    "lodash": "catalog:",
    "mdast-builder": "^1.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-abbr": "^1.4.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-variables": "^1.4.9",
    "unified": "^11.0.5",
    "unified-engine": "^11.2.2",
    "unist-builder": "^4.0.0",
    "unist-util-select": "^5.1.0",
    "unist-util-visit": "^5.0.0",
    "unist-util-visit-parents": "^6.0.2",
    "vfile": "^6.0.3",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "catalog:",
    "@types/mdast": "^4.0.4",
    "@types/node": "catalog:",
    "@types/unist": "^3.0.3",
    "cross-env": "^10.1.0",
    "jest": "catalog:",
    "rimraf": "^6.1.2",
    "ts-jest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}