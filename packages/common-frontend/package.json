{
  "name": "@saili/common-frontend",
  "version": "0.1.0",
  "description": "common-frontend",
  "license": "MIT",
  "keywords": [
    "common"
  ],
  "files": [
    "lib"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "clean": "rimraf lib && rimraf coverage",
    "format": "echo nop",
    "lint": "echo stub",
    "prepublishOnly": "yarn build",
    "prebuild": "yarn clean && yarn format && yarn lint && echo Using TypeScript && tsc --version",
    "build": "yarn compile",
    "buildCI": "yarn compile",
    "compile": "tsc -p tsconfig.build.json ",
    "watch": "yarn compile --watch"
  },
  "dependencies": {
    "@aws-amplify/core": "^6.15.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@saili/common-all": "workspace:^",
    "lodash": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-redux": "^9.2.0",
    "redux-logger": "^3.0.6"
  },
  "devDependencies": {
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/redux-logger": "^3.0.13"
  },
  "nohoist": [
    "**/common-all",
    "**/common-all/**"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}