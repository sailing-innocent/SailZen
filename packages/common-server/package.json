    "test:watch": "pnpm exec cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "pnpm exec cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "coverage": "pnpm test:coverage",
    "watch": "pnpm compile --watch"
  },
