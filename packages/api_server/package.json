{
  "name": "@saili/api-server",
  "version": "0.2.0",
  "type": "module",
  "description": "",
  "license": "MIT",
  "keywords": [],
  "files": [
    "lib"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "clean": "rimraf lib && rimraf coverage",
    "prepublishOnly": "pnpm build",
    "prebuild": "pnpm clean && echo Using TypeScript && tsc --version",
    "build": "pnpm compile",
    "compile": "tsc -p tsconfig.build.json",
    "watch": "pnpm compile --watch",
    "start:local": "cross-env PORT=3005 LOG_LEVEL=info nodemon --watch 'src/**/*.ts' lib/start.js",
    "start": "cross-env PORT=3005 LOG_LEVEL=info node lib/start.js",
    "start:integ:debug": "cross-env PORT=3005 TS_NODE_LOG_ERROR=1 NODE_OPTIONS='--loader ts-node/esm' node --inspect ./src/start.ts",
    "start:integ:watch": "cross-env PORT=3005 LOG_DST=../../logs/api-server.log LOG_LEVEL=debug NODE_OPTIONS='--loader ts-node/esm' nodemon --watch 'src/**/*.ts' --ignore 'src/**/*.spec.ts' ./src/start.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "catalog:",
    "@types/morgan": "^1.9.10",
    "@types/node": "catalog:",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@saili/common-all": "workspace:^",
    "@saili/common-server": "workspace:^",
    "@saili/engine-server": "workspace:^",
    "@saili/unified": "workspace:^",
    "cors": "^2.8.5",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "fs-extra": "^11.3.2",
    "klaw": "^4.1.0",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts, html",
    "ignore": [
      "src/public"
    ],
    "exec": "NODE_OPTIONS='--loader ts-node/esm' node --log-error ./src/start.ts"
  },
  "gitHead": "b9b209acf808ad7a581bf98b1d0f90ef2bf4b833"
}
