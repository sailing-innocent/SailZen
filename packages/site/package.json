{
    "name": "sail-site",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "cross-env NODE_ENV=development vite --mode=development",
        "debug": "cross-env NODE_ENV=debug vite --mode=debug",
        "build": "tsc --noEmit && cross-env NODE_ENV=production vite build --mode=production",
        "lint": "eslint .",
        "preview": "vite preview",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "cross-env NODE_ENV=development jest",
        "mock:install": "cd mock && bun install",
        "mock:start": "cd mock && bun run start",
        "mock:dev": "cd mock && bun run dev",
        "dev:full": "concurrently \"bun run mock:start\" \"bun run dev\""
    },
    "dependencies": {
        "@radix-ui/react-accordion": "^1.2.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-popover": "^1.1.14",
        "@radix-ui/react-select": "^2.2.5",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-tooltip": "^1.2.7",
        "@tailwindcss/vite": "^4.1.11",
        "@tanstack/react-table": "^8.21.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^0.539.0",
        "react": "^19.1.1",
        "react-day-picker": "^9.8.1",
        "react-dom": "^19.1.1",
        "react-router-dom": "^7.8.0",
        "recharts": "2.15.4",
        "tailwind-merge": "^3.3.1",
        "tailwindcss": "^4.1.11",
        "zustand": "^5.0.7"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "@storybook/addon-a11y": "^9.1.10",
        "@storybook/addon-themes": "^9.1.10",
        "@storybook/react-vite": "^9.1.10",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.2.1",
        "@types/react": "^19.1.9",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^4.7.0",
        "concurrently": "^9.1.0",
        "cross-env": "^10.0.0",
        "eslint": "^9.32.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.3.0",
        "jest": "^30.0.5",
        "storybook": "^9.1.10",
        "ts-jest": "^29.4.1",
        "tw-animate-css": "^1.3.6",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:",
        "vite": "^7.1.0",
        "eslint-plugin-storybook": "9.1.10"
    }
}