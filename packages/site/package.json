{
  "name": "sail-site",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite --mode=development",
    "debug": "cross-env NODE_ENV=debug vite --mode=debug",
    "build": "tsc --noEmit && cross-env NODE_ENV=production vite build --mode=production",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "cross-env NODE_ENV=development jest",
    "mock:install": "cd mock && bun install",
    "mock:start": "cd mock && bun run start",
    "mock:dev": "cd mock && bun run dev",
    "dev:full": "concurrently \"bun run mock:start\" \"bun run dev\""
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "recharts": "3.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-themes": "^10.1.10",
    "@storybook/react-vite": "^10.1.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "10.1.10",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "storybook": "^10.1.10",
    "ts-jest": "^29.4.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "^7.3.0"
  }
}
