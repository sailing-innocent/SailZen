{
  "$schema": "https://opencode.ai/config.json",
  "name": "SailZen Development",
  "description": "SailZen project with Python-priority agent configuration",
  "agent": {
    "default": {
      "description": "Prefer Python/bash over glob/grep for better performance",
      "mode": "primary",
      "prompt": ".opencode/agent/prefer-python.md",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "list": true,
        "glob": true,
        "grep": true,
        "patch": false,
        "todowrite": false,
        "todoread": false,
        "webfetch": false,
        "question": false,
        "skill": false
      },
      "permissions": {
        "bash": "allow",
        "edit": "allow",
        "write": "allow",
        "external": "allow"
      }
    },
    "python-only": {
      "description": "Strict Python-only mode (glob/grep disabled)",
      "mode": "primary", 
      "prompt": ".opencode/agent/python-priority.md",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "list": true,
        "glob": false,
        "grep": false,
        "patch": false,
        "todowrite": false,
        "todoread": false,
        "webfetch": false,
        "question": false,
        "skill": false
      },
      "permissions": {
        "bash": "allow",
        "edit": "allow",
        "write": "allow",
        "external": "allow"
      }
    },
    "explore": {
      "description": "Exploration mode with all read tools",
      "mode": "primary",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": true,
        "list": true,
        "glob": true,
        "grep": true,
        "patch": false,
        "todowrite": false,
        "todoread": false,
        "webfetch": true,
        "question": false,
        "skill": true
      },
      "permissions": {
        "bash": "ask",
        "webfetch": "ask"
      }
    }
  },
  "tools": {
    "glob": {
      "enabled": true
    },
    "grep": {
      "enabled": true
    }
  },
  "prompt": {
    "base": "You are a helpful coding assistant for the SailZen project. When searching files or content, prefer using bash commands (find, grep) or Python scripts over glob and grep tools for better performance."
  }
}
